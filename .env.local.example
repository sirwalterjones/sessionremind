# Copy this file to .env.local and fill in your own values. Never commit secrets.

# --- SMS (TextMagic) ---
# https://my.textmagic.com/online/api/rest-api/keys
TEXTMAGIC_API_KEY=your-textmagic-api-key
TEXTMAGIC_USERNAME=your-textmagic-username

# --- Token encryption / cron auth ---
ENCRYPTION_KEY=a-long-random-string
CRON_SECRET=a-long-random-string

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_BASE_URL=https://sessionremind.com

# --- Cloudflare Turnstile (signup/login bot wall) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x...
TURNSTILE_SECRET_KEY=0x...

# --- Email (Resend) ---
RESEND_API_KEY=re_...
RESEND_FROM=SessionRemind <noreply@yourdomain.com>

# --- Admin bootstrap (only needed to seed/promote an admin) ---
ADMIN_SEED_PASSWORD=
ADMIN_SETUP_SECRET=
